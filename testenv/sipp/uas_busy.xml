<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">
<!-- UAS handling REGISTER (branch) and INVITE: replies 486 Busy Here. -->
<scenario name="uas-busy">
  <recv request=".*" regexp_match="true">
    <action>
      <ereg regexp="REGISTER" search_in="hdr" header="CSeq:" check_it="false" assign_to="isreg" />
    </action>
  </recv>

  <nop test="isreg" next="do_register" />

  <!-- ============ INVITE branch: busy ============ -->
  <send>
    <![CDATA[

      SIP/2.0 486 Busy Here
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <recv request="ACK" next="done" />

  <!-- ============ REGISTER branch: plain 200 OK ============ -->
  <label id="do_register" />

  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTagReg[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      [last_Contact:]
      Expires: 300
      Content-Length: 0

    ]]>
  </send>

  <label id="done" />
  <nop />
</scenario>
