<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">
<!-- UAS handling REGISTER then INVITE: replies 486 Busy Here. -->
<scenario name="uas-busy">
  <recv request=".*" regexp_match="true">
    <action>
      <ereg regexp="REGISTER" search_in="hdr" header="CSeq:" check_it="false" assign_to="isreg" />
    </action>
  </recv>

  <nop test="isreg" next="do_register" />

  <!-- INVITE path: busy -->
  <label id="invite_handler" />

  <send>
    <![CDATA[
      SIP/2.0 486 Busy Here
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0
    ]]>
  </send>

  <recv request="ACK" timeout="5000" next="done" />

  <!-- REGISTER branch: 200 OK, then wait for INVITE -->
  <label id="do_register" />

  <send>
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTagReg[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      [last_Contact:]
      Expires: 300
      Content-Length: 0
    ]]>
  </send>

  <recv request="INVITE" next="invite_handler" />

  <label id="done" />
  <nop />
</scenario>
